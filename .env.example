# Sentinel configuration. Copy to `.env` and adjust.
# The docker-compose demo points these at the bundled mocks by default.

# --- Zabbix (JSON-RPC endpoint, usually .../api_jsonrpc.php) ---
ZABBIX_URL=http://mock-zabbix:8080/api_jsonrpc.php
ZABBIX_USER=monitor
ZABBIX_PASS=monitor
ZABBIX_MIN_SEVERITY=4          # 4 = High, 5 = Disaster

# --- Prometheus (base URL; /api/v1/query is appended) ---
PROMETHEUS_URL=http://mock-prometheus:8080

# --- Ollama (self-hosted LLM). Point at a real Ollama to use a real GPU. ---
OLLAMA_URL=http://mock-ollama:8080
OLLAMA_MODEL=qwen2.5:14b       # any Ollama model; keep it sized to your GPU
OLLAMA_TIMEOUT=300

# --- Notification: "inbox" (demo/CI, writes to a file + stdout) or "telegram" ---
NOTIFIER=inbox
INBOX_PATH=/data/inbox.jsonl
TELEGRAM_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# --- Guardrails ---
DEDUP_COOLDOWN_SEC=60          # suppress re-alerts for the same trigger within this window
MASS_OUTAGE_THRESHOLD=8        # this many new problems in one cycle trips the circuit breaker

# --- State ---
STATE_FILE=/data/state.json
